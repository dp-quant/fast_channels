# Environment variables (local dev)
# Copy to .env and adjust; docker-compose overrides as needed.
# WARNING: Do not use this file for production. Use environment variables or a secrets manager.

RABBIT_URL=amqp://guest:guest@rabbitmq:5672/
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=events

HTTP_HOST=0.0.0.0
HTTP_PORT=8000
GRPC_HOST=0.0.0.0
GRPC_PORT=50051
